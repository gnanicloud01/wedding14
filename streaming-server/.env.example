# ═══════════════════════════════════════════════════════════════
#  STREAMING SERVER CONFIG
#  Runs on Oracle Cloud VM alongside the transcoder (app.py)
# ═══════════════════════════════════════════════════════════════

# Cloudflare R2 Credentials (same as your oracle-worker/app.py)
R2_ACCESS_KEY=YOUR_R2_ACCESS_KEY
R2_SECRET_KEY=YOUR_R2_SECRET_KEY
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=wedding
R2_PUBLIC_DOMAIN=pub-d9695ac670454901abd1be0e246024b7.r2.dev

# Wedding OTT API (your Cloudflare Pages deployment)
NEXTJS_API_URL=https://ott.gtsounds.com
WEBHOOK_SECRET=dev-secret-123

# RTMP Server Config
RTMP_PORT=1935
HTTP_PORT=8443

# FFmpeg Settings
HLS_SEGMENT_DURATION=4
HLS_LIST_SIZE=10
