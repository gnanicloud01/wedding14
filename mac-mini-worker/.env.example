# Wedding OTT - Mac mini Worker Configuration
# Copy this to .env

# 1. API Configuration (Your Cloudflare Workers URL)
API_URL=https://wedding-ott.your-subdomain.workers.dev
ADMIN_SECRET=your_webhook_secret_here

# 2. Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=wedding-ott
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# 3. Local Paths
TEMP_DIR=./temp_processing
FFMPEG_PATH=ffmpeg
